# ==========================================
# Moonshine ASR Configuration
# ==========================================
# Copy to .env and adjust as needed.

# -----------------
# Host / Network
# -----------------
PORT=8200

# -----------------
# Models
# -----------------
# Language code (en/zh) to auto-download, or explicit path to model directory
MOONSHINE_EN_MODEL=en
MOONSHINE_ZH_MODEL=zh

# -----------------
# Devices (auto / cuda / cpu)
# -----------------
STT_DEVICE=auto
VAD_DEVICE=cpu
LID_DEVICE=cpu
DENOISE_DEVICE=cpu

# -----------------
# Pipeline
# -----------------
DENOISE_ENABLED=true
REQUEST_TIMEOUT=300
IDLE_TIMEOUT=0

# -----------------
# Logging
# -----------------
LOG_LEVEL=info

# -----------------
# WebSocket Streaming
# -----------------
# WS_BUFFER_SIZE=14400
# WS_FLUSH_SILENCE_MS=600
WS_WINDOW_MAX_S=6.0
ASR_USE_SERVER_VAD=true

# -----------------
# SSE Streaming
# -----------------
# SSE_CHUNK_SECONDS=5
# SSE_OVERLAP_SECONDS=1

# -----------------
# Docker / CUDA Internals
# -----------------
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
