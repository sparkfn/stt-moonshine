# ==========================================
# Moonshine ASR Configuration
# ==========================================
# Copy to .env and adjust as needed.

# -----------------
# Host / Network
# -----------------
PORT=8200

# -----------------
# Models
# -----------------
# Language code (en/zh) to auto-download, or explicit path to model directory
MOONSHINE_EN_MODEL=en
MOONSHINE_ZH_MODEL=zh

# -----------------
# Device
# -----------------
# Informational hint — ONNX Runtime selects CUDA/CPU provider automatically
STT_DEVICE=auto

# -----------------
# Timeouts
# -----------------
REQUEST_TIMEOUT=300
IDLE_TIMEOUT=0

# -----------------
# Logging
# -----------------
LOG_LEVEL=info

# -----------------
# WebSocket Streaming
# -----------------
# WS_BUFFER_SIZE=14400
# WS_FLUSH_SILENCE_MS=600
WS_WINDOW_MAX_S=6.0
# WS_AUTO_RESET_MS=800
# WS_PARTIAL=true
# WS_FLUSH_PAD_SILENCE=true

# -----------------
# SSE Streaming
# -----------------
# SSE_CHUNK_SECONDS=5
# SSE_OVERLAP_SECONDS=1

# -----------------
# Docker / CUDA Internals
# -----------------
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
